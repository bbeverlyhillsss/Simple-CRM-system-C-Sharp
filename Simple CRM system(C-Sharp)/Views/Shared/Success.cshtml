@{
    ViewData["Title"] = ViewBag.Title ?? "Успіх";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-body text-center p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            </div>
            <h2 class="text-success fw-bold">@ViewBag.Header</h2>
            <p class="lead">@ViewBag.Message</p>
            <hr />
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-action="Index" class="btn btn-outline-primary">До списку</a>

                @if (ViewBag.NextAction != null)
                {
                    <a asp-controller="@ViewBag.NextController" asp-action="@ViewBag.NextAction" class="btn btn-primary">
                        @ViewBag.NextLabel
                    </a>
                }
            </div>
        </div>
    </div>
</div>